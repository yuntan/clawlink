{
  "manifest_version": 3,
  "name": "ClawLink",
  "version": "1.0.0",
  "description": "iPhoneとブラウザのデータをOpenClawに送信する拡張",
  "permissions": [
    "tabs",
    "history",
    "storage",
    "alarms",
    "activeTab",
    "scripting",
    "offscreen"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
